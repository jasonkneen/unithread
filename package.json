{
  "name": "@jasonkneen/unithread",
  "version": "0.2.2",
  "description": "Isomorphic true-multithreading for JavaScript: one API over node:worker_threads and Web Workers. Function shipping, worker pools, RPC proxies, shared memory + Atomics.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run bundle && npm run skill:sync",
    "bundle": "esbuild src/index.ts --bundle --format=esm --platform=neutral --external:node:* --outfile=dist/unithread.bundle.js && esbuild src/index.ts --bundle --minify --format=esm --platform=neutral --external:node:* --outfile=dist/unithread.bundle.min.js",
    "skill:sync": "node scripts/sync-skill-asset.mjs",
    "test": "node test/proof.test.mjs",
    "test:browser": "node test/browser.test.mjs",
    "test:skill": "node --test skill/test/*.test.mjs",
    "demo": "node demo/serve.mjs",
    "prepublishOnly": "npm run build && npm test"
  },
  "sideEffects": false,
  "keywords": [
    "worker",
    "threads",
    "worker_threads",
    "web-worker",
    "multithreading",
    "atomics",
    "sharedarraybuffer",
    "pool",
    "isomorphic"
  ],
  "license": "MIT",
  "author": "Jason Kneen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkneen/unithread.git"
  },
  "homepage": "https://github.com/jasonkneen/unithread#readme",
  "bugs": {
    "url": "https://github.com/jasonkneen/unithread/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "playwright": "^1.61.1",
    "typescript": "^5.6.3"
  }
}
